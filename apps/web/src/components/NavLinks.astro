---
import { navLinks } from "../config/nav";

const currentPath = Astro.url.pathname;
const normalizedPath =
  currentPath === "/" ? "/" : currentPath.replace(/\/$/, "");
---

<nav aria-label="Primary">
  <ul
    class="menu menu-horizontal px-1 gap-1 lg:gap-2 xl:gap-8 flex-nowrap whitespace-nowrap"
  >
    {
      navLinks.map((link) => {
        const isActive =
          link.href === "/"
            ? normalizedPath === "/"
            : normalizedPath.startsWith(link.href);

        return (
          <li>
            <a
              href={link.href}
              class={`px-3 py-2 lg:px-4 lg:py-2.5 text-base transition-all duration-300 ease-in-out ${isActive ? "bg-sky-100 dark:bg-sky-900/40 text-primary dark:text-white font-bold shadow-sm" : "text-base-content font-medium hover:bg-base-100 hover:text-primary dark:hover:text-primary"}`}
              aria-current={isActive ? "page" : undefined}
            >
              {link.label}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>
