---
import { navLinks } from "../config/nav";

const currentPath = Astro.url.pathname;
const normalizedPath = currentPath === '/' ? '/' : currentPath.replace(/\/$/, '');
---

<ul class="menu menu-horizontal px-1 gap-1 lg:gap-2 xl:gap-4 2xl:gap-6 flex-nowrap whitespace-nowrap">
  {navLinks.map((link) => {
    const isActive = link.href === '/' 
      ? normalizedPath === '/' 
      : normalizedPath.startsWith(link.href);
      
    return (
      <li>
        <a 
          href={link.href}
          class={`px-3 py-2 lg:px-4 lg:py-2.5 2xl:px-5 2xl:py-3 text-base 2xl:text-lg transition-all duration-300 ease-in-out ${isActive ? 'bg-primary/10 text-primary dark:text-white font-bold underline underline-offset-4' : 'text-base-content font-medium hover:bg-base-200 hover:text-primary dark:hover:text-white'}`}
          aria-current={isActive ? "page" : undefined}
        >
          {link.label}
        </a>
      </li>
    );
  })}
</ul>
