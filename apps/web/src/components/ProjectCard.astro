---
import type { Project } from "../lib/projects";

export interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div class="card bg-base-100 shadow-lg border border-base-content/10 overflow-hidden group hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
  <figure class="relative aspect-[4/3] w-full overflow-hidden block m-0">
    <a href={`/our-work/${project.slug}`} class="block w-full h-full">
      <img
        src={project.afterImage || project.thumbnail}
        alt={project.title}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        loading="lazy"
      />
      
      {/* Badges overlaid on image */}
      <div class="absolute top-4 right-4 flex flex-col gap-2 z-10 items-end">
        <span class="rounded-full bg-primary/95 text-primary-content px-3 py-1.5 text-xs font-bold tracking-wide shadow-sm">
          {project.serviceType}
        </span>
        <span class="rounded-full bg-neutral/80 text-neutral-content backdrop-blur-sm px-3 py-1.5 text-xs font-medium shadow-sm capitalize">
          {project.location}
        </span>
      </div>
      
      {/* Gradient overlay to make text pop if added */}
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
    </a>
  </figure>
  
  <div class="card-body p-5">
    <a href={`/our-work/${project.slug}`} class="hover:text-primary transition-colors">
      <h3 class="card-title font-serif text-xl sm:text-2xl font-bold leading-tight line-clamp-2">
        {project.title}
      </h3>
    </a>
    
    <p class="text-base-content/80 text-sm mt-2 line-clamp-3">
      {project.shortDescription}
    </p>
    
    <div class="card-actions justify-end mt-4">
      <a 
        href={`/our-work/${project.slug}`} 
        class="btn btn-primary btn-sm btn-outline group/btn hover:text-primary-content"
      >
        View Case Study
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 transition-transform group-hover/btn:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</div>
