---
// WhyChooseUs.astro — "Why Choose Us" Trust Section (Step A)
// Pure Astro, zero JS, data is hardcoded trust pillars
---

<section
  aria-labelledby="why-choose-us-heading"
  class="py-24 sm:py-32 bg-base-200"
>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mx-auto max-w-2xl text-center mb-16">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-3">
        Why Cornwall Ponds
      </p>
      <h2
        id="why-choose-us-heading"
        class="font-serif text-3xl font-bold tracking-tight text-base-content sm:text-4xl"
      >
        Craftsmanship You Can Trust
      </h2>
      <p class="mt-4 text-lg text-base-content/70 leading-relaxed">
        Every project is built on three decades of quiet expertise, a love of nature,
        and an unwavering commitment to our clients.
      </p>
    </div>

    <!-- Trust Pillars Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

      <!-- Pillar 1: Experience -->
      <div class="trust-card group flex flex-col items-center text-center p-8 bg-base-100 rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
        <div
          class="pond-shape flex items-center justify-center w-16 h-16 bg-primary/10 text-primary mb-6 group-hover:bg-primary/20 transition-colors duration-300"
          aria-hidden="true"
        >
          <!-- Trophy icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 21h8m-4-4v4m-7-9V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v7M3 10a6 6 0 0 0 6 6h6a6 6 0 0 0 6-6H3Z" />
          </svg>
        </div>
        <h3 class="font-serif text-lg font-bold text-primary mb-2">30+ Years Experience</h3>
        <p class="text-base-content/70 text-sm leading-relaxed">
          Three decades designing and building bespoke water features across Cornwall and Devon.
        </p>
      </div>

      <!-- Pillar 2: Eco-First -->
      <div class="trust-card group flex flex-col items-center text-center p-8 bg-base-100 rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
        <div
          class="pond-shape flex items-center justify-center w-16 h-16 bg-primary/10 text-primary mb-6 group-hover:bg-primary/20 transition-colors duration-300"
          aria-hidden="true"
        >
          <!-- Leaf icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 2C6.5 2 2 6.5 2 12c0 2.4.86 4.6 2.29 6.33L12 22l7.71-3.67A10 10 0 0 0 22 12C22 6.5 17.5 2 12 2Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v20" />
          </svg>
        </div>
        <h3 class="font-serif text-lg font-bold text-primary mb-2">Eco-First Design</h3>
        <p class="text-base-content/70 text-sm leading-relaxed">
          Wildlife-friendly construction using natural materials, native planting, and chemical-free filtration.
        </p>
      </div>

      <!-- Pillar 3: Certified & Insured -->
      <div class="trust-card group flex flex-col items-center text-center p-8 bg-base-100 rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
        <div
          class="pond-shape flex items-center justify-center w-16 h-16 bg-primary/10 text-primary mb-6 group-hover:bg-primary/20 transition-colors duration-300"
          aria-hidden="true"
        >
          <!-- Shield-check icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
        </div>
        <h3 class="font-serif text-lg font-bold text-primary mb-2">Certified &amp; Insured</h3>
        <p class="text-base-content/70 text-sm leading-relaxed">
          Fully qualified, insured, and members of the British Pond Trade Association.
        </p>
      </div>

      <!-- Pillar 4: Lifetime Support -->
      <div class="trust-card group flex flex-col items-center text-center p-8 bg-base-100 rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
        <div
          class="pond-shape flex items-center justify-center w-16 h-16 bg-primary/10 text-primary mb-6 group-hover:bg-primary/20 transition-colors duration-300"
          aria-hidden="true"
        >
          <!-- Chat-bubble-heart icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78Z" />
          </svg>
        </div>
        <h3 class="font-serif text-lg font-bold text-primary mb-2">Lifetime Support</h3>
        <p class="text-base-content/70 text-sm leading-relaxed">
          We don't disappear after build day. Every project includes ongoing aftercare advice.
        </p>
      </div>

    </div>

    <!-- Bottom anchor stat strip -->
    <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-8 pt-12 border-t border-base-300">
      <div class="text-center">
        <p class="font-serif text-4xl font-bold text-primary">200+</p>
        <p class="text-sm text-base-content/60 mt-1">Projects Completed</p>
      </div>
      <div class="text-center">
        <p class="font-serif text-4xl font-bold text-primary">30+</p>
        <p class="text-sm text-base-content/60 mt-1">Years of Experience</p>
      </div>
      <div class="text-center">
        <p class="font-serif text-4xl font-bold text-primary">100%</p>
        <p class="text-sm text-base-content/60 mt-1">Chemical-Free Options</p>
      </div>
      <div class="text-center">
        <p class="font-serif text-4xl font-bold text-primary">5★</p>
        <p class="text-sm text-base-content/60 mt-1">Average Client Rating</p>
      </div>
    </div>
  </div>
</section>
