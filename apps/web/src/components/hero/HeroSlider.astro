---
const slides = [
  {
    image: "/images/hero-pond.jpg",
    title: "Bespoke Pond Design",
    subtitle: "for Cornwall & Devon",
    description:
      "Cornwall's premier pond specialists. We design, build and maintain stunning water features that transform outdoor spaces into living works of art.",
    priority: true,
  },
  {
    image: "/images/swimming-pond.jpg",
    title: "Natural Swimming Ponds",
    subtitle: "Chemical-free luxury",
    description:
      "Experience the luxury of swimming in crystal-clear, chemical-free water in your own garden. The ultimate natural outdoor feature.",
    priority: false,
  },
  {
    image: "/images/koi-pond.jpg",
    title: "Specialist Koi Ponds",
    subtitle: "Engineered for perfection",
    description:
      "We build specialist koi ponds engineered with advanced filtration systems for the health and wellbeing of these magnificent fish.",
    priority: false,
  },
  {
    image: "/images/maintenance.jpg",
    title: "Pond Maintenance",
    subtitle: "Professional year-round care",
    description:
      "Keep your pond in pristine condition year-round with our professional maintenance, cleaning, and restoration services.",
    priority: false,
  },
];
---

<section
  class="hero min-h-[600px] h-screen max-h-[1100px] relative overflow-hidden bg-black"
  id="hero-slider"
  role="region"
  aria-roledescription="carousel"
  aria-label="Featured pond projects slideshow"
>
  {
    slides.map((slide, index) => (
      <div
        class={`slide absolute inset-0 transition-opacity duration-1000 flex items-center justify-center ${index === 0 ? "opacity-100 z-10" : "opacity-0 z-0"}`}
        data-index={index}
        aria-hidden={index !== 0 ? "true" : "false"}
        role="group"
        aria-roledescription="slide"
        aria-label={`Slide ${index + 1} of ${slides.length}: ${slide.title}`}
      >
        {/* Background Image Loading Architecture (LCP vs Lazy) */}
        <img
          src={slide.image}
          alt={slide.title}
          fetchpriority={slide.priority ? "high" : "auto"}
          loading={slide.priority ? "eager" : "lazy"}
          decoding={slide.priority ? "sync" : "async"}
          class="absolute inset-0 w-full h-full object-cover z-0"
        />
        {/* Foreground Content */}
        <div class="hero-content text-center relative z-10 w-full max-w-5xl mx-auto px-4 py-8 sm:px-12 sm:py-16 mt-16 sm:mt-24 bg-[radial-gradient(ellipse_at_center,rgba(0,0,0,0.7)_0%,rgba(0,0,0,0.5)_50%,transparent_80%)]">
          <div class="max-w-4xl mx-auto flex flex-col items-center gap-6 sm:gap-8">
            {/* Premium Glassmorphism Badge w/ Trust Signals */}
            <div class="inline-flex items-center gap-2 rounded-full border border-white/30 bg-white/10 px-4 py-1.5 text-xs font-medium tracking-wide text-white backdrop-blur-sm shadow-sm md:text-sm">
              <span
                class="flex items-center gap-0.5 text-[#F5B041]"
                aria-hidden="true"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              </span>
              <span class="opacity-90 font-bold uppercase tracking-wider">
                Over 15 years of delivering excellence
              </span>
            </div>

            {/* Main Luxury Typography & SEO Node injection */}
            {index === 0 ? (
              <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-sans font-bold tracking-tight text-white leading-tight text-balance">
                {slide.title} <br class="hidden sm:block" />
                <span class="text-white/90 italic font-serif font-light text-3xl sm:text-4xl md:text-5xl lg:text-6xl mt-2 block">
                  {slide.subtitle}
                </span>
              </h1>
            ) : (
              <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-sans font-bold tracking-tight text-white leading-tight text-balance">
                {slide.title} <br class="hidden sm:block" />
                <span class="text-white/90 italic font-serif font-light text-3xl sm:text-4xl md:text-5xl lg:text-6xl mt-2 block">
                  {slide.subtitle}
                </span>
              </h2>
            )}

            <p class="text-base sm:text-lg text-white/80 font-medium max-w-2xl mx-auto leading-relaxed mt-2 text-balance lg:min-h-12">
              {slide.description}
            </p>

            {/* Luxury CTAs */}
            <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 mt-6 w-full sm:w-auto overflow-hidden">
              <a
                href="/contact"
                class="btn bg-primary text-primary-foreground hover:bg-primary/90 btn-lg shadow-lg shadow-primary/30 w-full sm:w-auto font-bold text-base px-8 border-none pond-shape"
              >
                Request a Free Quote
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 ml-2"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"
                  />
                </svg>
              </a>
              <a
                href="/our-work"
                class="btn btn-outline hover:bg-white/20 bg-white/10 backdrop-blur-sm text-white border-white/30 btn-lg w-full sm:w-auto font-bold text-base px-8 transition-all pond-shape"
              >
                View Our Work
              </a>
            </div>
          </div>
        </div>
      </div>
    ))
  }

  {/* Slide Controls & Indicators */}
  <div class="absolute bottom-8 left-0 right-0 z-30 flex flex-col items-center gap-3">
    <div
      class="flex justify-center gap-3"
      aria-label="Hero slides"
    >
      {
        slides.map((_, index) => (
          <button
            class={`indicator-btn h-2 w-8 rounded-full transition-all duration-500 cursor-pointer focus:outline-none focus-visible:ring-2 ring-white ring-offset-2 ring-offset-black/50 ${index === 0 ? "bg-white" : "bg-white/30 hover:bg-white/50"}`}
            data-index={index}
            type="button"
            aria-label={`Go to slide ${index + 1}`}
            aria-pressed={index === 0 ? "true" : "false"}
            aria-current={index === 0 ? "true" : undefined}
          />
        ))
      }
    </div>
    <button
      type="button"
      data-hero-slider-pause
      class="mt-1 inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-xs font-medium text-white border border-white/40 backdrop-blur-sm hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-black/60"
      aria-pressed="false"
    >
      Pause slideshow
    </button>
  </div>
</section>

<script>
  import { initHeroSlider } from "./hero-slider-init";

  function attachHeroSlider() {
    const sliderContainer = document.getElementById("hero-slider");
    if (!sliderContainer) return;

    // Delay initialization slightly so we don't compete with first paint.
    window.requestAnimationFrame(() => {
      initHeroSlider(sliderContainer, { intervalMs: 7000 });
    });
  }

  document.addEventListener("astro:page-load", attachHeroSlider);

  if (
    document.readyState === "complete" ||
    document.readyState === "interactive"
  ) {
    attachHeroSlider();
  } else {
    document.addEventListener("DOMContentLoaded", attachHeroSlider);
  }
</script>
