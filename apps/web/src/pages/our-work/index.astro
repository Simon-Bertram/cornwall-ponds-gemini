---
import Layout from "../../layouts/Layout.astro";
import { Portfolio } from "../../components/Portfolio";
import { projects } from "../../lib/projects";
---

<Layout 
  title="Our Portfolio | Cornwall Ponds" 
  description="Explore our recent pond designs, natural swimming ponds, and water features across Cornwall."
>
  <main class="py-24 sm:py-32 bg-base-100 min-h-screen">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center my-16">
        <h1 class="font-serif text-4xl font-bold tracking-tight text-base-content sm:text-5xl lg:text-6xl mb-6">
          Our Portfolio
        </h1>
        <p class="text-lg text-base-content/80">
          From intimate garden ponds in St Ives to sweeping natural swimming pools in Bude, 
          explore our recent transformations across the county.
        </p>
      </div>

      <div class="mt-16">
        <Portfolio client:load projects={projects} />
      </div>
    </div>
  </main>
</Layout>
