---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Privacy Policy | Cornwall Ponds">
  <main class="min-h-[60vh] bg-base-100">
    <section class="py-16 sm:py-24">
      <div class="mx-auto max-w-3xl px-6 lg:px-8">
        <h1 class="font-serif text-3xl sm:text-4xl font-bold tracking-tight text-base-content mb-6">
          Privacy Policy
        </h1>
        <p class="text-base text-base-content/80 leading-relaxed">
          This is a placeholder for the Cornwall Ponds privacy policy. It will
          describe how we collect, use, and protect your personal information.
        </p>
      </div>
    </section>
  </main>
</Layout>

