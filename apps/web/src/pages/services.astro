---
// apps/web/src/pages/services.astro
// Moved from services/index.astro to fix Astro 6 beta CSS asset resolution bug
// with sub-directory index pages.

import Layout from "../layouts/Layout.astro";
import GetStarted from "../components/GetStarted.astro";
import { services, projects, testimonials } from "../lib/projects";

const guidePrices = [
  { service: "Garden Ponds", price: "From £3,500" },
  { service: "Natural Swimming Ponds", price: "From £18,000" },
  { service: "Koi Ponds", price: "From £6,000" },
  { service: "Water Features", price: "From £1,200" },
  { service: "Pond Maintenance", price: "From £180/visit" },
];

const credentials = [
  {
    title: "Fully Insured",
    body: "Public Liability & Employer's Liability",
    svgPath: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  },
  {
    title: "BALI Registered",
    body: "British Association of Landscape Industries",
    svgPath: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z",
  },
  {
    title: "Water Quality Certified",
    body: "Regular testing & documentation",
    svgPath: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
  },
  {
    title: "Finance Available",
    body: "FCA-registered options on request",
    svgPath: "M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z",
  },
];
---

<Layout
  title="Our Services | Bespoke Pond Design & Build | Cornwall Ponds"
  description="Explore the full range of bespoke pond design and build services in Cornwall. From garden ponds to luxury natural swimming ponds. Free site visit and quote."
>
  <main class="min-h-screen">

    <!-- ── Section 1: Our Services title + summary + service cards ── -->
    <section class="py-24 sm:py-32 bg-base-100">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center py-16 mb-16">
          <h1 class="font-serif text-4xl font-bold tracking-tight text-base-content sm:text-5xl lg:text-6xl mb-6">
            Our Services
          </h1>
          <p class="text-lg text-base-content/80">
            From bespoke garden ponds and natural swimming pools to koi ponds, water features, and year-round maintenance — we design, build, and care for water in your landscape across Cornwall.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {services.map((service) => (
            <a
              href={`#${service.slug}`}
              class="group flex flex-col rounded-2xl border border-base-content/10 bg-base-100 p-6 sm:p-8 shadow-sm hover:shadow-xl hover:border-primary/30 transition-all duration-300 focus-visible:ring-2 ring-primary ring-offset-2"
              aria-label={`View ${service.title} details`}
            >
              <div class="flex-1 flex flex-col">
                <div class="w-full aspect-4/3 max-h-40 rounded-xl overflow-hidden bg-base-200/60 mb-6">
                  <img
                    src={service.image}
                    alt={`${service.title} — Cornwall Ponds`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
                <h2 class="font-serif text-xl font-bold text-base-content mb-2 group-hover:text-primary transition-colors">
                  {service.title}
                </h2>
                <p class="text-sm text-base-content/70 leading-relaxed flex-1">
                  {service.shortDescription}
                </p>
                <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-primary group-hover:gap-3 transition-all">
                  Learn more
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Section 2: Philosophy Strip ── -->
    <section class="py-16 bg-base-200">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
          <div class="flex flex-col items-center">
            <div class="bg-primary/10 p-4 rounded-2xl mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <h3 class="font-serif text-xl font-bold text-base-content mb-2">Nature-First Design</h3>
            <p class="text-base-content/70 text-sm leading-relaxed">Every feature is designed to work with your ecosystem. Wildlife and longevity are embedded from day one.</p>
          </div>
          <div class="flex flex-col items-center">
            <div class="bg-primary/10 p-4 rounded-2xl mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-serif text-xl font-bold text-base-content mb-2">Rooted in Cornwall</h3>
            <p class="text-base-content/70 text-sm leading-relaxed">15 years in Cornwall means we understand your soil, your coastline, and your weather — not just general principles.</p>
          </div>
          <div class="flex flex-col items-center">
            <div class="bg-primary/10 p-4 rounded-2xl mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-serif text-xl font-bold text-base-content mb-2">Built to Last</h3>
            <p class="text-base-content/70 text-sm leading-relaxed">Full aftercare documentation and optional lifetime support come with every build we complete.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Section 3: Alternating Service Blocks ── -->
    <section>
      {services.map((service, i) => {
        const example = projects.find(p => p.serviceType === service.title) ?? projects[i % projects.length];
        return (
          <div id={service.slug} class={`py-24 sm:py-32 scroll-mt-20 ${i % 2 === 0 ? 'bg-base-100' : 'bg-base-200'}`}>
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
              <div class={`flex flex-col items-center gap-12 lg:gap-20 lg:flex-row ${i % 2 !== 0 ? 'lg:flex-row-reverse' : ''}`}>

                <!-- Content Column -->
                <div class="flex-1 min-w-0">
                  <span class="badge badge-outline badge-primary font-bold text-xs tracking-wider px-4 py-3 mb-6">
                    {service.title}
                  </span>
                  <h2 class="font-serif text-3xl sm:text-4xl font-bold text-base-content mt-4 mb-6">
                    {service.title}
                  </h2>
                  <p class="text-base sm:text-lg text-base-content/80 leading-relaxed mb-8">
                    {service.description}
                  </p>

                  <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3 mb-10">
                    {service.features.map((feature) => (
                      <li class="flex items-start gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                        <span class="text-sm font-medium text-base-content/70">{feature}</span>
                      </li>
                    ))}
                  </ul>

                  <div class="flex flex-wrap gap-4 items-center">
                    <a href={`/contact?service=${service.id}`} class="btn btn-primary px-8">
                      Request a Quote
                    </a>
                    <a href={`/our-work/${example.slug}`} class="flex items-center gap-3 group">
                      <div class="w-12 h-12 rounded-xl overflow-hidden shrink-0 border border-base-content/10">
                        <img src={example.thumbnail} alt={example.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                      </div>
                      <div>
                        <p class="text-[10px] uppercase tracking-widest font-bold text-base-content/40">See our work</p>
                        <p class="text-sm font-semibold text-base-content group-hover:text-primary transition-colors">{example.title}</p>
                      </div>
                    </a>
                  </div>
                </div>

                <!-- Image Column -->
                <div class="flex-1 w-full">
                  <div class="aspect-4/3 rounded-3xl overflow-hidden shadow-2xl">
                    <img
                      src={service.image}
                      alt={`Cornwall Ponds — ${service.title}`}
                      class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                    />
                  </div>
                </div>

              </div>
            </div>
          </div>
        );
      })}
    </section>

    <!-- ── Section 4: Investment Guide ── -->
    <section class="py-24 bg-primary text-primary-content">
      <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
        <h2 class="font-serif text-3xl sm:text-4xl font-bold mb-4">Investment Guide</h2>
        <p class="text-lg opacity-80 mb-12 max-w-2xl mx-auto">
          We pride ourselves on transparency. These guide prices help you baseline your project requirements.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-6">
          {guidePrices.map((item) => (
            <div class="bg-white/10 border border-white/20 p-6 rounded-2xl">
              <p class="text-xs font-bold uppercase tracking-widest opacity-60 mb-3">{item.service}</p>
              <p class="text-2xl font-serif font-bold">{item.price}</p>
            </div>
          ))}
        </div>

        <p class="mt-10 text-sm italic opacity-60 max-w-2xl mx-auto">
          Guide figures only. Your exact quote follows a free site visit and design consultation — no obligation.
        </p>
      </div>
    </section>

    <!-- ── Section 5: Credentials ── -->
    <section class="py-24 bg-neutral text-neutral-content">
      <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
        <h2 class="font-serif text-3xl sm:text-4xl font-bold mb-4">Professional Standards</h2>
        <p class="opacity-70 mb-16 max-w-xl mx-auto">
          We don't just build ponds — we engineer living ecosystems, backed by verifiable credentials.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
          {credentials.map((cred) => (
            <div class="flex flex-col items-center">
              <div class="w-16 h-16 rounded-full border border-white/20 bg-white/5 flex items-center justify-center mb-5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={cred.svgPath} />
                </svg>
              </div>
              <h4 class="font-bold text-base mb-2">{cred.title}</h4>
              <p class="text-sm opacity-60 leading-relaxed">{cred.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Section 6: Testimonials ── -->
    <section class="py-24 bg-base-200">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="font-serif text-3xl sm:text-4xl font-bold text-base-content">What Our Clients Say</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {testimonials.slice(0, 3).map((t) => (
            <div class="bg-base-100 p-8 rounded-3xl border border-base-content/5 shadow-sm flex flex-col">
              <div class="flex gap-1 text-primary mb-5">
                {[...Array(5)].map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-base-content/80 text-sm leading-relaxed italic mb-6 flex-1">"{t.quote}"</p>
              <div>
                <p class="font-bold text-sm text-base-content">{t.name}</p>
                <p class="text-xs text-base-content/50">{t.location}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Section 7: Final CTA ── -->
    <GetStarted />

  </main>
</Layout>
