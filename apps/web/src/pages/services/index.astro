---
// apps/web/src/pages/services/index.astro
// Implementation: frontend-engineer
// Role: full services deep-dive with alternating layouts and pricing transparency

import Layout from "../../layouts/Layout.astro";
import GetStarted from "../../components/GetStarted.astro";
import { services, projects, testimonials } from "../../lib/projects";

// Find one featured project for each service type to use as a "live example"
const getExampleProject = (serviceType: string) => {
  return projects.find((p) => p.serviceType === serviceType) || projects[0];
};

const guidePrices = [
  { service: "Garden Ponds", price: "From £3,500" },
  { service: "Natural Swimming Ponds", price: "From £18,000" },
  { service: "Koi Ponds", price: "From £6,000" },
  { service: "Water Features", price: "From £1,200" },
  { service: "Pond Maintenance", price: "From £180/visit" },
];

const credentials = [
  { title: "Fully Insured", body: "Public Liability & Employer's Liability", icon: "shield" },
  { title: "BALI Registered", body: "British Association of Landscape Industries", icon: "badge" },
  { title: "Water Quality Certified", body: "Regular testing & documentation", icon: "water" },
  { title: "FCA-Registered", body: "Finance options available on request", icon: "finance" },
];
---

<Layout
  title="Our Services | Bespoke Pond Design & Build | Cornwall Ponds"
  description="Explore the full range of bespoke pond design and build services in Cornwall. From garden ponds to luxury swimming ponds. Free site visit."
>
  <main class="min-h-screen">
    
    {/* ── Section 1: Hero ── */}
    <section class="bg-foreground text-background py-24 sm:py-32 lg:py-40">
      <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
        <div class="mx-auto max-w-3xl">
          <span class="text-sm font-bold uppercase tracking-widest text-primary-foreground/60 mb-6 block">
            Our Expertise
          </span>
          <h1 class="font-serif text-4xl font-bold tracking-tight text-background sm:text-6xl lg:text-7xl mb-8 leading-tight">
            Water. Transformed.<br />
            <span class="italic text-primary-foreground/90">Into Something Extraordinary.</span>
          </h1>
          <p class="text-xl leading-relaxed text-background/80 mb-10 max-w-2xl mx-auto">
            Every pond we build is unique — shaped by your landscape, your vision, and Cornwall's exceptional natural environment.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
            <a href="/our-work" class="btn btn-primary btn-wide shadow-xl shadow-primary/20">
              View Our Portfolio
            </a>
            <a href="/contact" class="btn btn-ghost btn-wide text-background hover:bg-white/10">
              Book a Consultation
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ── Section 2: Philosophy Strip ── */}
    <section class="py-16 bg-base-200 border-b border-base-300">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
          <div class="flex flex-col items-center">
            <div class="bg-primary/10 p-3 rounded-2xl mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <h3 class="font-serif text-xl font-bold mb-2">Nature-First Design</h3>
            <p class="text-base-content/70 text-sm">Every feature is designed to work with your ecosystem. Wildlife and longevity are embedded from day one.</p>
          </div>
          <div class="flex flex-col items-center">
            <div class="bg-primary/10 p-3 rounded-2xl mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-serif text-xl font-bold mb-2">Rooted in Cornwall</h3>
            <p class="text-base-content/70 text-sm">15 years in Cornwall means we understand your soil, your coastline, and your weather.</p>
          </div>
          <div class="flex flex-col items-center">
            <div class="bg-primary/10 p-3 rounded-2xl mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-serif text-xl font-bold mb-2">Built to Last</h3>
            <p class="text-base-content/70 text-sm">We provide full aftercare documentation and optional lifetime support with every build.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ── Section 3: Alternating Service Blocks ── */}
    <section class="overflow-hidden">
      {services.map((service, i) => {
        const example = getExampleProject(service.title);
        const isEven = i % 2 === 0;
        
        return (
          <div id={service.slug} class={`py-24 sm:py-32 scroll-mt-20 ${isEven ? 'bg-base-100' : 'bg-base-200'}`}>
            <div class="mx-auto max-w-7xl px-6 lg:px-8">
              <div class={`flex flex-col gap-12 lg:gap-24 lg:flex-row ${!isEven ? 'lg:flex-row-reverse' : ''} items-center`}>
                
                {/* Content Column */}
                <div class="flex-1">
                  <span class="badge badge-primary badge-outline font-bold text-xs px-4 py-3 mb-6">
                    {service.title}
                  </span>
                  <h2 class="font-serif text-3xl font-bold text-base-content sm:text-4xl mb-6">
                    {service.title}
                  </h2>
                  <p class="text-lg text-base-content/80 leading-relaxed mb-8">
                    {service.description}
                  </p>
                  
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 mb-10">
                    {service.features.map((feature) => (
                      <div class="flex items-center gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                        </svg>
                        <span class="text-sm font-medium text-base-content/70">{feature}</span>
                      </div>
                    ))}
                  </div>

                  <div class="flex flex-col sm:flex-row gap-4">
                    <a href={`/contact?service=${service.id}`} class="btn btn-primary px-8">
                      Request a Quote for {service.title}
                    </a>
                    {/* Example cross-reference */}
                    <div class="flex items-center gap-4 px-4 py-2 bg-base-300/30 rounded-xl border border-base-content/5">
                      <div class="w-12 h-12 rounded-lg bg-base-300 overflow-hidden shrink-0">
                        <img src={example.thumbnail} alt={example.title} class="w-full h-full object-cover" />
                      </div>
                      <div class="flex flex-col">
                        <span class="text-[10px] uppercase tracking-wider font-bold text-base-content/40">Latest Project</span>
                        <a href={`/our-work/${example.slug}`} class="text-[13px] font-bold text-base-content underline decoration-primary/30 hover:decoration-primary transition-all">
                          {example.title}
                        </a>
                      </div>
                    </div>
                  </div>
                </div>

                {/* Image Column */}
                <div class="flex-1 w-full max-w-2xl lg:max-w-none">
                  <div class="aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl bg-base-300">
                    <img 
                      src={service.image} 
                      alt={`Expert construction of ${service.title}`} 
                      class="w-full h-full object-cover" 
                    />
                  </div>
                </div>

              </div>
            </div>
          </div>
        );
      })}
    </section>

    {/* ── Section 4: Pricing Transparency ── */}
    <section class="py-24 bg-primary text-primary-foreground">
      <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
        <h2 class="font-serif text-3xl font-bold mb-4">Investment Guide</h2>
        <p class="text-lg text-primary-foreground/80 mb-12 max-w-2xl mx-auto">
          We pride ourselves on transparency. These guide prices help you baseline your project requirements.
        </p>
        
        <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-6">
          {guidePrices.map((item) => (
            <div class="bg-white/10 backdrop-blur-sm border border-white/20 p-6 rounded-2xl flex flex-col justify-center">
              <h4 class="text-sm font-bold uppercase tracking-widest opacity-60 mb-2">{item.service}</h4>
              <p class="text-2xl font-serif font-bold">{item.price}</p>
            </div>
          ))}
        </div>
        
        <p class="mt-12 text-sm italic opacity-60 max-w-2xl mx-auto">
          * All prices are indicative guide figures. Every project is bespoke — your exact quote will be provided after a comprehensive site visit and design consultation.
        </p>
      </div>
    </section>

    {/* ── Section 5: Technical Credentials ── */}
    <section class="py-24 bg-foreground text-background">
      <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
        <h2 class="font-serif text-3xl font-bold mb-12">Professional Standards</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
          {credentials.map((cred) => (
            <div class="flex flex-col items-center">
              <div class="w-16 h-16 rounded-full border border-background/20 flex items-center justify-center mb-6">
                 {/* Simple placeholder icon logic or SVG selection could go here */}
                 <div class="w-8 h-8 bg-background/10 rounded-full" />
              </div>
              <h4 class="font-bold text-lg mb-2 text-background">{cred.title}</h4>
              <p class="text-sm text-background/60 leading-relaxed">{cred.body}</p>
            </div>
          ))}
        </div>
        <div class="mt-16 max-w-2xl mx-auto">
          <p class="text-background/80 text-lg leading-relaxed">
            "We don't just build ponds. We engineer living ecosystems — and we back our work with professional standards you can verify."
          </p>
        </div>
      </div>
    </section>

    {/* ── Section 6: Testimonials ── */}
    <section class="py-24 bg-base-200">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="font-serif text-3xl font-bold">What Our Clients Say</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {testimonials.slice(0, 3).map((t) => (
            <div class="bg-base-100 p-8 rounded-3xl shadow-sm border border-base-content/5">
              <div class="flex gap-1 text-primary mb-4">
                {[...Array(5)].map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-base-content/80 text-sm italic mb-6">"{t.quote}"</p>
              <div class="flex flex-col">
                <span class="font-bold text-base-content">{t.name}</span>
                <span class="text-xs text-base-content/50">{t.location}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Section 7: CTA ── */}
    <GetStarted />

  </main>
</Layout>
