# Cloudflare API (required when not using `bunx wrangler login`; e.g. CI, Dev Container)
# Create token at https://dash.cloudflare.com → My Profile → API Tokens (D1 Edit, Workers Edit, Account Settings Read)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Alchemy secret encryption (required for alchemy.secret.env bindings; generate: openssl rand -base64 32)
ALCHEMY_PASSWORD=

# App bindings – use placeholder URLs for first deploy, then replace with URLs printed after deploy
PUBLIC_SERVER_URL=https://server.<your-subdomain>.workers.dev
CORS_ORIGIN=https://web.<your-subdomain>.pages.dev
BETTER_AUTH_URL=https://server.<your-subdomain>.workers.dev

# Better Auth session signing (generate: openssl rand -base64 32)
BETTER_AUTH_SECRET=
